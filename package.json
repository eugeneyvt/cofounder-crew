{
  "name": "cofounder-crew",
  "version": "0.1.14",
  "description": "Codex-backed local team runtime",
  "keywords": [
    "codex",
    "ai-agents",
    "mcp",
    "local-first",
    "developer-tools",
    "cli",
    "multi-agent"
  ],
  "homepage": "https://github.com/eugeneyvt/cofounder-crew#readme",
  "bugs": {
    "url": "https://github.com/eugeneyvt/cofounder-crew/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eugeneyvt/cofounder-crew.git"
  },
  "license": "MIT",
  "type": "module",
  "types": "./dist/src/runtime.d.ts",
  "files": [
    "dist/src",
    "README.md",
    "docs"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/runtime.d.ts",
      "import": "./dist/src/runtime.js"
    },
    "./init": {
      "types": "./dist/src/init.d.ts",
      "import": "./dist/src/init.js"
    },
    "./setup": {
      "types": "./dist/src/setup.d.ts",
      "import": "./dist/src/setup.js"
    },
    "./templates": {
      "types": "./dist/src/templates.d.ts",
      "import": "./dist/src/templates.js"
    }
  },
  "bin": {
    "cofounder": "dist/src/cli.js",
    "cofounder-mcp": "dist/src/mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/src/cli.js dist/src/mcp.js dist/src/worker.js",
    "check": "tsc -p tsconfig.json --noEmit && node scripts/check-ts-hygiene.mjs",
    "check:package": "npm run build && publint run --strict && publint run packages/create-cofounder --strict",
    "test": "tsx --test tests/*.test.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check && npm test && npm run check:package"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "smol-toml": "^1.3.1",
    "yaml": "^2.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "publint": "^0.3.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
