{
  "name": "cofounder-crew",
  "version": "0.1.6",
  "description": "Codex-backed local team runtime",
  "homepage": "https://github.com/eugeneyvt/cofounder-crew#readme",
  "bugs": {
    "url": "https://github.com/eugeneyvt/cofounder-crew/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eugeneyvt/cofounder-crew.git"
  },
  "type": "module",
  "files": [
    "dist/src",
    "README.md"
  ],
  "exports": {
    ".": "./dist/src/runtime.js",
    "./init": "./dist/src/init.js",
    "./setup": "./dist/src/setup.js",
    "./templates": "./dist/src/templates.js"
  },
  "bin": {
    "cofounder": "dist/src/cli.js",
    "cofounder-mcp": "dist/src/mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/src/cli.js dist/src/mcp.js dist/src/worker.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "prepack": "npm run build"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "smol-toml": "^1.3.1",
    "yaml": "^2.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
